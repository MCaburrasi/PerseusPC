<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="95.0" prefWidth="340.0" style="-fx-background-radius: 18; -fx-background-color: FDF; -fx-padding: 8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="caburrasi.marcos.perseus.components.event.EventController">
   <children>
      <HBox layoutX="18.0" layoutY="14.0" prefHeight="51.0" prefWidth="248.0" style="-fx-spacing: 12;">
         <children>
            <ImageView fx:id="logo" fitHeight="67.0" fitWidth="63.0" pickOnBounds="true" preserveRatio="true" />
            <FlowPane prefHeight="68.0" prefWidth="151.0">
               <children>
                  <Label fx:id="name" prefHeight="38.0" prefWidth="171.0" style="-fx-text-fill: BLACK;" text="Label">
                     <font>
                        <Font size="26.0" />
                     </font>
                  </Label>
                  <Label fx:id="timeAndPlace" prefHeight="30.0" prefWidth="172.0" style="-fx-text-fill: BLACK;" text="Label">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Label>
               </children>
            </FlowPane>
            <FontIcon fx:id="options" iconLiteral="mdi-dots-vertical" iconSize="62" wrappingWidth="57.0" />
         </children>
      </HBox>
   </children>
</AnchorPane>
