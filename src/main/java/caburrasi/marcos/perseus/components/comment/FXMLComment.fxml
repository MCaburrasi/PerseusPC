<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="201.0" prefWidth="288.0" style="-fx-background-radius: 18; -fx-background-color: FDF; -fx-padding: 12;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="caburrasi.marcos.perseus.components.comment.CommentController">
   <children>
      <VBox layoutX="21.0" layoutY="21.0" prefHeight="200.0" prefWidth="100.0" style="-fx-spacing: 12;">
         <children>
            <HBox prefHeight="32.0" prefWidth="246.0">
               <children>
                  <ImageView fx:id="pfp" fitHeight="44.0" fitWidth="44.0" pickOnBounds="true" preserveRatio="true" />
                  <FlowPane prefHeight="16.0" prefWidth="202.0" style="-fx-alignment: CENTER LEFT;">
                     <children>
                        <Label fx:id="name" prefHeight="17.0" prefWidth="202.0" style="-fx-text-fill: BLACK;" text="Label">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </FlowPane>
               </children>
            </HBox>
            <Label fx:id="content" alignment="TOP_LEFT" prefHeight="118.0" prefWidth="272.0" style="-fx-text-fill: BLACK;" text="Label" />
            <HBox prefHeight="42.0" prefWidth="246.0" style="-fx-spacing: 12;">
               <children>
                  <FontIcon fx:id="like" iconLiteral="mdi-heart-outline" iconSize="32" wrappingWidth="32.0" />
                  <FontIcon fx:id="comment" iconLiteral="mdi-comment-processing" iconSize="32" wrappingWidth="32.0" />
                  <FontIcon fx:id="send" iconLiteral="mdi-send" iconSize="32" wrappingWidth="32.0" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
